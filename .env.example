# -----------------------------------------------------------------------------
# RegPortal environment variables
# Copy this file to ".env.local" and fill in the values below.
# .env.local is git-ignored, so your secrets stay on your machine.
# -----------------------------------------------------------------------------

# Required — a random string used to sign Auth.js sessions.
# Generate one with:
#   npx auth secret
# or from https://generate-secret.vercel.app/32
NEXTAUTH_SECRET=

# The public URL of the app. Leave as-is for local development.
NEXTAUTH_URL=http://localhost:3000

# Optional — Neon Postgres connection string.
# Leave BLANK to run RegPortal in demo mode (in-memory state, no database needed).
# Format:
#   postgres://<user>:<password>@<host>/<database>?sslmode=require
DATABASE_URL=

# Optional — Groq API key powering the four AI features.
# Get one at https://console.groq.com/keys
# Leave BLANK and the app will use grounded fallback replies instead.
GROQ_API_KEY=
